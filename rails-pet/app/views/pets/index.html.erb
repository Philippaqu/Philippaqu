<h1>My Pets</h1>

<ul>
  <% @pets.each do |pet| %>
  <li><%= pet.name %> | <%= pet.gender %> | <%= pet.category %> | <%= pet.address %> | We found him/her <%= time_ago_in_words(pet.found_on) %></li>
  <%= link_to "See the details", pet_path(pet.id) %>
  <%= link_to "Edit", edit_pet_path(pet) %>
  <% end %>
</ul>
